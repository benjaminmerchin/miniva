# Copy the relevant values into ~/.hermes/.env on the server.

DISCORD_BOT_TOKEN_MASTER=
ELEVENLABS_API_KEY=
OPENROUTER_API_KEY=

VOICE_API_SECRET=
VOICE_AGENT_SHARED_TOKEN=

# Frontend build values
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=
VITE_SITE_URL=
