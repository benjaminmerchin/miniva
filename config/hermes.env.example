# Copy the relevant values into ~/.hermes/.env on the server.

DISCORD_BOT_TOKEN_MASTER=
ELEVENLABS_API_KEY=
OPENROUTER_API_KEY=

VOICE_API_SECRET=
VOICE_AGENT_SHARED_TOKEN=

# Frontend build values
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=
VITE_SITE_URL=
VITE_DODO_PRODUCT_ID=
VITE_DODO_MODE=test

# Optional overrides
HERMES_VOICE_EXEC_ENABLED=true
HERMES_VOICE_AGENT=voice
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it
DISCORD_ENABLE_VOICE=1

# Google Calendar OAuth (per-Discord-user). Set these to enable
# the "!calendar" command and "connect to my calendar" flow.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public base URL the bot is reachable at (no trailing slash). Used to build
# the OAuth2 redirect URI: <CALENDAR_PUBLIC_BASE_URL>/calendar/oauth2callback
CALENDAR_PUBLIC_BASE_URL=
# Where the voice_api server listens (used by the Discord bot to call it).
CALENDAR_API_BASE=http://127.0.0.1:8080
